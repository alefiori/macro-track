# Supabase — copy this file to .env and fill in your project's values.
# Settings → API in the Supabase dashboard.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# External food lookups run server-side in the `food-search` Edge Function, so
# their API keys are NOT set here (they'd be exposed in the browser bundle).
# Set them as function secrets instead, e.g. the optional USDA key (free —
# https://fdc.nal.usda.gov/api-key-signup.html; defaults to DEMO_KEY if unset):
#   supabase secrets set USDA_API_KEY=your-key

# --- Premium (Stripe) -------------------------------------------------------
# OPTIONAL display-only prices shown on the upgrade card (e.g. "$4.99").
# The authoritative amount always lives in the Stripe Price; leave unset to
# show only the plan name and reveal the price at Checkout.
VITE_PREMIUM_PRICE_MONTHLY=
VITE_PREMIUM_PRICE_ANNUAL=

# The Stripe SECRET key, webhook secret, and Price IDs are NOT set here — they
# stay server-side as Edge Function secrets (never shipped to the browser):
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_... \
#     STRIPE_WEBHOOK_SECRET=whsec_... \
#     STRIPE_PRICE_MONTHLY=price_... STRIPE_PRICE_ANNUAL=price_...
# Optional: APP_URL=https://your-app.example.com (fallback for Checkout return
# URLs; the browser normally passes its own origin).
#
# Deploy the billing functions:
#   supabase functions deploy create-checkout-session
#   supabase functions deploy create-portal-session
#   supabase functions deploy stripe-webhook --no-verify-jwt   # Stripe sends no JWT
