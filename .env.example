# Supabase — copy this file to .env and fill in your project's values.
# Settings → API in the Supabase dashboard.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# External food lookups run server-side in the `food-search` Edge Function, so
# their API keys are NOT set here (they'd be exposed in the browser bundle).
# Set them as function secrets instead, e.g. the optional USDA key (free —
# https://fdc.nal.usda.gov/api-key-signup.html; defaults to DEMO_KEY if unset):
#   supabase secrets set USDA_API_KEY=your-key
# and the optional Edamam Food Database credentials (free tier —
# https://developer.edamam.com/food-database-api; source is skipped if unset):
#   supabase secrets set EDAMAM_APP_ID=your-app-id EDAMAM_APP_KEY=your-app-key
# and the optional Open Food Facts account (skips OFF's anonymous rate limit;
# OFF has no API key — auth is HTTP Basic; requests stay anonymous if unset):
#   supabase secrets set OFF_USERNAME=your-off-user OFF_PASSWORD=your-off-password
